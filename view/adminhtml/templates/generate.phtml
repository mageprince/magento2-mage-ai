<?php
/**
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Mageprince\MageAI\Helper\Data $helper
 * @var \Magento\Framework\Escaper $escaper
 */
// phpcs:disable Generic.Files.LineLength
// phpcs:disable Magento2.Templates.ThisInTemplate
$helper = $this->helper(\Mageprince\MageAI\Helper\Data::class);
$isEnabled = $helper->isEnabled();
?>
<?php if ($isEnabled): ?>
    <?php
    $generateAjaxUrl = $block->getUrl('mp_mageai/index/generate');
    $generateImageAjaxUrl = $block->getUrl('mp_mageai/index/generateimage');
    ?>

    <!-- Text content generation modal -->
    <div id="advanced-generate-modal" style="display:none;">
        <div class="generate-modal-body-content">
            <form id="mp-prompt-generate-form">
                <fieldset class="admin__fieldset">
                    <div class="admin__field admin__field-wide">
                        <div class="admin__field-control">
                            <textarea
                                type="text"
                                rows="3"
                                id="mp-custom-prompt"
                                class="admin__control-text"
                                placeholder="E.g. Create an engaging HTML product description using the following details:&#10;Product Name: Proteus Fitness Jackshirt&#10;Color: Blue"
                                name="custom_prompt"></textarea>
                            <div class="admin__field-note mpai-modal-note">
                                <span>
                                    <?= $escaper->escapeHtml(__('Please provide key details to generate your custom content.')) ?>
                                </span>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </form>
        </div>
    </div>

    <!-- Image generation modal -->
    <div id="mp-image-generate-modal" style="display:none;">
        <div class="generate-modal-body-content">
            <fieldset class="admin__fieldset">
                <div class="admin__field admin__field-wide">
                    <div class="admin__field-control">
                        <textarea
                            rows="4"
                            id="mp-image-prompt"
                            class="admin__control-text"
                            placeholder="<?= $escaper->escapeHtmlAttr(__('E.g. A professional product photo on a white background, studio lighting, e-commerce style')) ?>"
                            name="image_prompt"></textarea>
                        <div class="admin__field-note mpai-modal-note">
                            <span>
                                <?= $escaper->escapeHtml(__('Leave empty to use the default image prompt configured in Stores > Configuration > Mageprince > Mage AI > Image Generation.')) ?>
                            </span>
                        </div>
                    </div>
                </div>
            </fieldset>
        </div>
    </div>

    <script>
        window.mageAIAjaxUrl = '<?= $escaper->escapeJs($generateAjaxUrl) ?>';
        window.mageAIGenerateImageUrl = '<?= $escaper->escapeJs($generateImageAjaxUrl) ?>';
        window.isMpMageAIEnabled = '<?= $escaper->escapeJs($isEnabled) ?>';
        window.mpMageAIAttributes = <?= /* @noEscape */ json_encode($helper->getProductAttributes()) ?>;
        window.mpMageAIImageAttributes = <?= /* @noEscape */ json_encode($helper->getImageAttributes()) ?>;
    </script>
    <script type="text/x-magento-init">
        {
            "#mp-prompt-generate-form": {
                "mageAiGenerate": {}
            },
            "#mp-image-generate-modal": {
                "mageAiImageGenerate": {}
            }
        }
    </script>
<?php endif ?>
